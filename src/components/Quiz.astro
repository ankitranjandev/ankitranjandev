---
interface Question {
  question: string;
  options: string[];
  correctIndex: number;
  explanation: string;
}

interface Props {
  title: string;
  description: string;
  questions: Question[];
  subjectTitle: string;
}

const { title, description, questions, subjectTitle } = Astro.props;
---

<section id="quiz-section" class="scroll-mt-24">
  <div class="quiz-container" data-questions={JSON.stringify(questions)} data-subject={subjectTitle}>
    <!-- Quiz Intro -->
    <div class="quiz-intro rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-6 md:p-8">
      <div class="mb-6 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <path d="M12 17h.01"/>
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-[var(--text)] md:text-2xl">{title}</h2>
          <p class="text-sm text-[var(--text-secondary)]">{questions.length} questions</p>
        </div>
      </div>
      <p class="mb-6 text-[var(--text-secondary)]">{description}</p>
      <button
        type="button"
        class="quiz-start-btn inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 font-medium text-white transition-colors hover:bg-accent-hover"
      >
        Start Quiz
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- Quiz Questions (hidden initially) -->
    <div class="quiz-questions hidden">
      <!-- Progress bar -->
      <div class="mb-6 flex items-center gap-4">
        <span class="quiz-progress-text text-sm font-medium text-[var(--text-secondary)]">Question 1 of {questions.length}</span>
        <div class="h-2 flex-1 overflow-hidden rounded-full bg-[var(--bg)]">
          <div class="quiz-progress-bar h-full rounded-full bg-accent transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Question card -->
      <div class="quiz-question-card rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-6 md:p-8">
        <h3 class="quiz-question-text mb-6 text-lg font-semibold text-[var(--text)] md:text-xl"></h3>

        <div class="quiz-options space-y-3"></div>

        <!-- Explanation (hidden until answered) -->
        <div class="quiz-explanation mt-6 hidden rounded-lg border border-[var(--border)] bg-[var(--bg)] p-4">
          <div class="mb-2 flex items-center gap-2 text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="explanation-icon">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 16v-4"/>
              <path d="M12 8h.01"/>
            </svg>
            <span class="explanation-title">Explanation</span>
          </div>
          <p class="quiz-explanation-text text-sm text-[var(--text-secondary)]"></p>
        </div>

        <!-- Next button -->
        <button
          type="button"
          class="quiz-next-btn mt-6 hidden w-full items-center justify-center gap-2 rounded-lg bg-accent px-6 py-3 font-medium text-white transition-colors hover:bg-accent-hover"
        >
          Next Question
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Quiz Results (hidden initially) -->
    <div class="quiz-results hidden">
      <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-6 md:p-8">
        <div class="mb-8 text-center">
          <div class="quiz-result-icon mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-full">
            <!-- Icon will be inserted by JS -->
          </div>
          <h2 class="quiz-result-title mb-2 text-2xl font-bold text-[var(--text)]"></h2>
          <p class="quiz-result-message text-[var(--text-secondary)]"></p>
        </div>

        <!-- Score display -->
        <div class="mb-8 rounded-xl bg-[var(--bg)] p-6 text-center">
          <div class="mb-2 text-4xl font-bold text-accent">
            <span class="quiz-score">0</span>/<span class="quiz-total">{questions.length}</span>
          </div>
          <p class="text-sm text-[var(--text-secondary)]">
            <span class="quiz-percentage">0</span>% correct
          </p>
        </div>

        <!-- Share badge -->
        <div class="quiz-share-section">
          <p class="mb-4 text-center text-sm font-medium text-[var(--text)]">Share your achievement</p>

          <!-- Badge preview -->
          <div class="quiz-badge mx-auto mb-6 max-w-sm overflow-hidden rounded-xl border border-[var(--border)] bg-gradient-to-br from-accent/5 to-accent/10 p-6">
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-accent text-2xl font-bold text-white">
                <span class="badge-score">0</span>
              </div>
              <div class="min-w-0">
                <p class="truncate font-semibold text-[var(--text)]">{subjectTitle} Quiz</p>
                <p class="text-sm text-[var(--text-secondary)]">
                  Scored <span class="badge-percentage">0</span>% on ankitranjan.dev
                </p>
              </div>
            </div>
          </div>

          <!-- Share buttons -->
          <div class="flex flex-wrap justify-center gap-3">
            <button
              type="button"
              class="share-twitter inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] transition-colors hover:border-[var(--text-tertiary)] hover:text-[var(--text)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Share on X
            </button>
            <button
              type="button"
              class="share-linkedin inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] transition-colors hover:border-[var(--text-tertiary)] hover:text-[var(--text)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Share on LinkedIn
            </button>
            <button
              type="button"
              class="share-copy inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] transition-colors hover:border-[var(--text-tertiary)] hover:text-[var(--text)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
              <span class="copy-text">Copy Link</span>
            </button>
          </div>
        </div>

        <!-- Retry button -->
        <div class="mt-8 text-center">
          <button
            type="button"
            class="quiz-retry-btn inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:underline"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
              <path d="M21 3v5h-5"/>
              <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
              <path d="M8 16H3v5"/>
            </svg>
            Retry Quiz
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  interface Question {
    question: string;
    options: string[];
    correctIndex: number;
    explanation: string;
  }

  class QuizManager {
    private container: HTMLElement;
    private questions: Question[];
    private subject: string;
    private currentIndex = 0;
    private score = 0;
    private answered = false;

    constructor(container: HTMLElement) {
      this.container = container;
      this.questions = JSON.parse(container.dataset.questions || '[]');
      this.subject = container.dataset.subject || 'Quiz';
      this.init();
    }

    private init() {
      // Start button
      const startBtn = this.container.querySelector('.quiz-start-btn');
      startBtn?.addEventListener('click', () => this.startQuiz());

      // Next button
      const nextBtn = this.container.querySelector('.quiz-next-btn');
      nextBtn?.addEventListener('click', () => this.nextQuestion());

      // Retry button
      const retryBtn = this.container.querySelector('.quiz-retry-btn');
      retryBtn?.addEventListener('click', () => this.retryQuiz());

      // Share buttons
      this.container.querySelector('.share-twitter')?.addEventListener('click', () => this.shareTwitter());
      this.container.querySelector('.share-linkedin')?.addEventListener('click', () => this.shareLinkedIn());
      this.container.querySelector('.share-copy')?.addEventListener('click', () => this.copyLink());
    }

    private startQuiz() {
      this.container.querySelector('.quiz-intro')?.classList.add('hidden');
      this.container.querySelector('.quiz-questions')?.classList.remove('hidden');
      this.renderQuestion();
    }

    private renderQuestion() {
      const question = this.questions[this.currentIndex];
      const questionText = this.container.querySelector('.quiz-question-text');
      const optionsContainer = this.container.querySelector('.quiz-options');
      const progressText = this.container.querySelector('.quiz-progress-text');
      const progressBar = this.container.querySelector<HTMLElement>('.quiz-progress-bar');
      const explanation = this.container.querySelector('.quiz-explanation');
      const nextBtn = this.container.querySelector('.quiz-next-btn');

      if (!questionText || !optionsContainer) return;

      // Update progress
      const progress = (this.currentIndex / this.questions.length) * 100;
      if (progressText) progressText.textContent = `Question ${this.currentIndex + 1} of ${this.questions.length}`;
      if (progressBar) progressBar.style.width = `${progress}%`;

      // Reset state
      this.answered = false;
      explanation?.classList.add('hidden');
      nextBtn?.classList.add('hidden');
      nextBtn?.classList.remove('flex');

      // Render question
      questionText.textContent = question.question;

      // Render options
      optionsContainer.innerHTML = question.options
        .map(
          (option, index) => `
          <button
            type="button"
            class="quiz-option group flex w-full items-center gap-3 rounded-lg border border-[var(--border)] bg-[var(--bg)] p-4 text-left text-[var(--text)] transition-all hover:border-[var(--text-tertiary)]"
            data-index="${index}"
          >
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] text-sm font-medium transition-colors group-hover:border-accent group-hover:bg-accent/10 group-hover:text-accent">
              ${String.fromCharCode(65 + index)}
            </span>
            <span>${option}</span>
          </button>
        `
        )
        .join('');

      // Add click handlers to options
      optionsContainer.querySelectorAll('.quiz-option').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const index = parseInt(target.dataset.index || '0', 10);
          this.selectAnswer(index);
        });
      });
    }

    private selectAnswer(selectedIndex: number) {
      if (this.answered) return;
      this.answered = true;

      const question = this.questions[this.currentIndex];
      const isCorrect = selectedIndex === question.correctIndex;

      if (isCorrect) this.score++;

      // Update option styles
      const options = this.container.querySelectorAll('.quiz-option');
      options.forEach((option, index) => {
        const btn = option as HTMLButtonElement;
        btn.disabled = true;
        btn.classList.remove('hover:border-[var(--text-tertiary)]');

        const letterSpan = btn.querySelector('span:first-child');

        if (index === question.correctIndex) {
          btn.classList.add('border-green-500', 'bg-green-500/5');
          btn.classList.remove('border-[var(--border)]');
          letterSpan?.classList.add('border-green-500', 'bg-green-500/10', 'text-green-600');
          letterSpan?.classList.remove('border-[var(--border)]', 'bg-[var(--bg-secondary)]');
        } else if (index === selectedIndex && !isCorrect) {
          btn.classList.add('border-red-500', 'bg-red-500/5');
          btn.classList.remove('border-[var(--border)]');
          letterSpan?.classList.add('border-red-500', 'bg-red-500/10', 'text-red-600');
          letterSpan?.classList.remove('border-[var(--border)]', 'bg-[var(--bg-secondary)]');
        }
      });

      // Show explanation
      const explanation = this.container.querySelector('.quiz-explanation');
      const explanationText = this.container.querySelector('.quiz-explanation-text');
      const explanationIcon = this.container.querySelector('.explanation-icon');
      const explanationTitle = this.container.querySelector('.explanation-title');

      if (explanation && explanationText) {
        explanationText.textContent = question.explanation;
        explanation.classList.remove('hidden');

        if (isCorrect) {
          explanation.classList.add('border-green-500/30', 'bg-green-500/5');
          explanationIcon?.classList.add('text-green-600');
          if (explanationTitle) explanationTitle.textContent = 'Correct!';
        } else {
          explanation.classList.add('border-red-500/30', 'bg-red-500/5');
          explanationIcon?.classList.add('text-red-600');
          if (explanationTitle) explanationTitle.textContent = 'Incorrect';
        }
      }

      // Show next button
      const nextBtn = this.container.querySelector('.quiz-next-btn');
      if (nextBtn) {
        nextBtn.classList.remove('hidden');
        nextBtn.classList.add('flex');
        if (this.currentIndex === this.questions.length - 1) {
          nextBtn.innerHTML = `
            See Results
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          `;
        }
      }
    }

    private nextQuestion() {
      // Reset explanation styles
      const explanation = this.container.querySelector('.quiz-explanation');
      explanation?.classList.remove('border-green-500/30', 'bg-green-500/5', 'border-red-500/30', 'bg-red-500/5');
      this.container.querySelector('.explanation-icon')?.classList.remove('text-green-600', 'text-red-600');

      this.currentIndex++;

      if (this.currentIndex < this.questions.length) {
        this.renderQuestion();
      } else {
        this.showResults();
      }
    }

    private showResults() {
      this.container.querySelector('.quiz-questions')?.classList.add('hidden');
      this.container.querySelector('.quiz-results')?.classList.remove('hidden');

      const percentage = Math.round((this.score / this.questions.length) * 100);

      // Update score displays
      const scoreEl = this.container.querySelector('.quiz-score');
      const percentageEl = this.container.querySelector('.quiz-percentage');
      const badgeScore = this.container.querySelector('.badge-score');
      const badgePercentage = this.container.querySelector('.badge-percentage');

      if (scoreEl) scoreEl.textContent = this.score.toString();
      if (percentageEl) percentageEl.textContent = percentage.toString();
      if (badgeScore) badgeScore.textContent = this.score.toString();
      if (badgePercentage) badgePercentage.textContent = percentage.toString();

      // Update result message based on score
      const resultIcon = this.container.querySelector('.quiz-result-icon');
      const resultTitle = this.container.querySelector('.quiz-result-title');
      const resultMessage = this.container.querySelector('.quiz-result-message');

      if (percentage >= 80) {
        if (resultIcon) {
          resultIcon.classList.add('bg-green-500/10');
          resultIcon.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600">
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/>
              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/>
              <path d="M4 22h16"/>
              <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/>
              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/>
              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
            </svg>
          `;
        }
        if (resultTitle) resultTitle.textContent = 'Excellent!';
        if (resultMessage) resultMessage.textContent = "You've mastered this topic. Great job!";
      } else if (percentage >= 60) {
        if (resultIcon) {
          resultIcon.classList.add('bg-accent/10');
          resultIcon.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
            </svg>
          `;
        }
        if (resultTitle) resultTitle.textContent = 'Good Job!';
        if (resultMessage) resultMessage.textContent = "You have a solid understanding. Review the topics you missed to improve.";
      } else {
        if (resultIcon) {
          resultIcon.classList.add('bg-orange-500/10');
          resultIcon.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-orange-500">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          `;
        }
        if (resultTitle) resultTitle.textContent = 'Keep Learning!';
        if (resultMessage) resultMessage.textContent = "Review the topics above and try again. You'll do better next time!";
      }
    }

    private retryQuiz() {
      this.currentIndex = 0;
      this.score = 0;
      this.answered = false;

      // Reset result icon classes
      const resultIcon = this.container.querySelector('.quiz-result-icon');
      resultIcon?.classList.remove('bg-green-500/10', 'bg-accent/10', 'bg-orange-500/10');

      this.container.querySelector('.quiz-results')?.classList.add('hidden');
      this.container.querySelector('.quiz-intro')?.classList.remove('hidden');
    }

    private getShareText() {
      const percentage = Math.round((this.score / this.questions.length) * 100);
      return `I scored ${percentage}% on the ${this.subject} Quiz on ankitranjan.dev! Test your knowledge too:`;
    }

    private shareTwitter() {
      const text = encodeURIComponent(this.getShareText());
      const url = encodeURIComponent(window.location.href);
      window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank');
    }

    private shareLinkedIn() {
      const url = encodeURIComponent(window.location.href);
      window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, '_blank');
    }

    private async copyLink() {
      const copyBtn = this.container.querySelector('.share-copy');
      const copyText = copyBtn?.querySelector('.copy-text');

      try {
        await navigator.clipboard.writeText(window.location.href);
        if (copyText) {
          copyText.textContent = 'Copied!';
          setTimeout(() => {
            copyText.textContent = 'Copy Link';
          }, 2000);
        }
      } catch {
        // Fallback
        if (copyText) copyText.textContent = 'Failed';
      }
    }
  }

  // Initialize all quiz containers
  document.querySelectorAll<HTMLElement>('.quiz-container').forEach((container) => {
    new QuizManager(container);
  });
</script>
