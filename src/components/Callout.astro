---
interface Props {
  type?: 'note' | 'warning' | 'tip';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const styles = {
  note: {
    border: 'border-l-accent',
    bg: 'bg-accent/5',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>`,
    defaultTitle: 'Note',
  },
  warning: {
    border: 'border-l-amber-500',
    bg: 'bg-amber-500/5',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>`,
    defaultTitle: 'Warning',
  },
  tip: {
    border: 'border-l-emerald-500',
    bg: 'bg-emerald-500/5',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><path d="M12 2v8"></path><path d="m4.93 10.93 1.41 1.41"></path><path d="M2 18h2"></path><path d="M20 18h2"></path><path d="m19.07 10.93-1.41 1.41"></path><path d="M22 22H2"></path><path d="m8 6 4-4 4 4"></path><path d="M16 18a4 4 0 0 0-8 0"></path></svg>`,
    defaultTitle: 'Tip',
  },
};

const style = styles[type];
const displayTitle = title ?? style.defaultTitle;
---

<aside class={`not-prose my-6 border-l-4 ${style.border} ${style.bg} rounded-r-md p-4`} role="note">
  <div class="flex items-start gap-3">
    <div class="mt-0.5 shrink-0" set:html={style.icon} />
    <div class="min-w-0 flex-1">
      <p class="mb-1 font-semibold text-[var(--text)]">{displayTitle}</p>
      <div class="text-[var(--text-secondary)] [&>p]:mb-0">
        <slot />
      </div>
    </div>
  </div>
</aside>
