---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/Prose.astro';
import TagPill from '@/components/TagPill.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import LiteYouTube from '@/components/LiteYouTube.astro';
import ShareLinks from '@/components/ShareLinks.astro';
import Giscus from '@/components/Giscus.astro';
import { formatDate, getReadingTimeFromBody, filterDrafts } from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return filterDrafts(posts).map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTimeFromBody(post.body ?? '');

const ogImage = post.data.ogImage ?? `/og/${post.id}.png`;

const canonicalURL = new URL(`/blog/${post.id}/`, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Ankit Ranjan',
    url: 'https://ankitranjan.dev',
  },
  publisher: {
    '@type': 'Person',
    name: 'Ankit Ranjan',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://ankitranjan.dev',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: 'https://ankitranjan.dev/blog/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: canonicalURL,
    },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={ogImage}
  ogType="article"
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  tags={post.data.tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="content-grid py-12 md:py-16">
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-[var(--text-secondary)]">
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        <span aria-hidden="true">·</span>
        <span>{readingTime}</span>
        {post.data.updatedAt && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formatDate(post.data.updatedAt)}</span>
          </>
        )}
      </div>
      <h1 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl" style="font-size: clamp(2rem, 4vw + 1rem, 3rem); line-height: 1.1;">
        {post.data.title}
      </h1>
      <p class="text-lg text-[var(--text-secondary)]">{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <TagPill tag={tag} linked />
          ))}
        </div>
      )}
    </header>

    {post.data.heroVideo && (
      <div class="mb-10 flex justify-center">
        <LiteYouTube id={post.data.heroVideo} title={post.data.title} />
      </div>
    )}

    <div class="relative lg:grid lg:grid-cols-[1fr_200px] lg:gap-8">
      <Prose>
        <Content />
      </Prose>
      <TableOfContents headings={headings} />
    </div>

    <div class="mt-10 border-t border-[var(--border)] pt-6">
      <ShareLinks title={post.data.title} url={new URL(`/blog/${post.id}/`, Astro.site).href} />
    </div>

    <Giscus />
  </article>
</BaseLayout>
