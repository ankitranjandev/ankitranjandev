---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Example data for the visualizer
const examples = [
  {
    id: 'simple-text',
    title: 'Simple Text',
    code: `Text('Hello')`,
    description: 'A single widget creates one Element and one RenderObject. The simplest 1:1:1 relationship.',
    widgetTree: [
      { id: 'w1', label: 'Text', type: 'widget', depth: 0 }
    ],
    elementTree: [
      { id: 'e1', label: 'RichTextElement', type: 'element', depth: 0, linkedTo: 'w1' }
    ],
    renderTree: [
      { id: 'r1', label: 'RenderParagraph', type: 'render', depth: 0, linkedTo: 'e1' }
    ],
    notes: [
      'Text widget internally uses RichText, which creates a RenderParagraph.',
      'The Element holds a reference to both the Widget and the RenderObject.',
      'When you call setState(), a new Text widget is created, but the Element is reused.'
    ]
  },
  {
    id: 'column-children',
    title: 'Column with Children',
    code: `Column(
  children: [
    Text('First'),
    Text('Second'),
  ],
)`,
    description: 'Parent widgets create child Elements and RenderObjects. The tree structure mirrors across all three trees.',
    widgetTree: [
      { id: 'w1', label: 'Column', type: 'widget', depth: 0 },
      { id: 'w2', label: 'Text', type: 'widget', depth: 1, parent: 'w1' },
      { id: 'w3', label: 'Text', type: 'widget', depth: 1, parent: 'w1' }
    ],
    elementTree: [
      { id: 'e1', label: 'MultiChildRenderObjectElement', type: 'element', depth: 0, linkedTo: 'w1' },
      { id: 'e2', label: 'RichTextElement', type: 'element', depth: 1, parent: 'e1', linkedTo: 'w2' },
      { id: 'e3', label: 'RichTextElement', type: 'element', depth: 1, parent: 'e1', linkedTo: 'w3' }
    ],
    renderTree: [
      { id: 'r1', label: 'RenderFlex', type: 'render', depth: 0, linkedTo: 'e1' },
      { id: 'r2', label: 'RenderParagraph', type: 'render', depth: 1, parent: 'r1', linkedTo: 'e2' },
      { id: 'r3', label: 'RenderParagraph', type: 'render', depth: 1, parent: 'r1', linkedTo: 'e3' }
    ],
    notes: [
      'Column is a Flex widget that arranges children vertically.',
      'RenderFlex handles the actual layout calculations (main axis, cross axis).',
      'Each child has its own Element and RenderObject in the subtree.'
    ]
  },
  {
    id: 'stateless-widget',
    title: 'StatelessWidget',
    code: `class Greeting extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Text('Hello');
  }
}

// Usage:
Greeting()`,
    description: 'StatelessWidget creates an Element but no RenderObject. It delegates rendering to its child.',
    widgetTree: [
      { id: 'w1', label: 'Greeting', type: 'widget', depth: 0, isComposite: true },
      { id: 'w2', label: 'Text', type: 'widget', depth: 1, parent: 'w1' }
    ],
    elementTree: [
      { id: 'e1', label: 'StatelessElement', type: 'element', depth: 0, linkedTo: 'w1', isComposite: true },
      { id: 'e2', label: 'RichTextElement', type: 'element', depth: 1, parent: 'e1', linkedTo: 'w2' }
    ],
    renderTree: [
      { id: 'r1', label: 'RenderParagraph', type: 'render', depth: 0, linkedTo: 'e2' }
    ],
    notes: [
      'StatelessWidget is a "compositional" widget — it composes other widgets.',
      'StatelessElement exists in the Element tree, but has no RenderObject.',
      'Only leaf RenderObjectWidgets (like Text, Container) create RenderObjects.'
    ]
  },
  {
    id: 'stateful-rebuild',
    title: 'StatefulWidget Rebuild',
    code: `class Counter extends StatefulWidget {
  @override
  State<Counter> createState() => _CounterState();
}

class _CounterState extends State<Counter> {
  int count = 0;

  @override
  Widget build(BuildContext context) {
    return Text('$count');
  }
}

// After setState():
// New Text widget, same Element`,
    description: 'When setState() runs, a NEW widget is created, but the Element is REUSED. This is Flutter\'s efficiency trick.',
    widgetTree: [
      { id: 'w1', label: 'Counter', type: 'widget', depth: 0, isStateful: true },
      { id: 'w2', label: 'Text', type: 'widget', depth: 1, parent: 'w1', isNew: true }
    ],
    elementTree: [
      { id: 'e1', label: 'StatefulElement', type: 'element', depth: 0, linkedTo: 'w1', isStateful: true, isReused: true },
      { id: 'e2', label: 'RichTextElement', type: 'element', depth: 1, parent: 'e1', linkedTo: 'w2', isReused: true }
    ],
    renderTree: [
      { id: 'r1', label: 'RenderParagraph', type: 'render', depth: 0, linkedTo: 'e2', isUpdated: true }
    ],
    notes: [
      'Widgets are IMMUTABLE — setState() always creates new widget instances.',
      'Elements are MUTABLE — they hold State and get reused across rebuilds.',
      'The Element compares old and new widgets (canUpdate) to decide reuse.',
      'RenderObjects update their properties without being recreated.'
    ]
  }
];
---

<BaseLayout
  title="Flutter Tree Visualiser"
  description="Interactive visualisation of Flutter's Widget, Element, and RenderObject trees. See how the three trees work together."
>
  <div class="page-container py-12 md:py-20">
    <header class="mb-10">
      <h1 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">Flutter Tree Visualiser</h1>
      <p class="max-w-[60ch] text-lg text-[var(--text-secondary)]">
        See how Flutter's three trees — Widget, Element, and RenderObject — work together.
        Select an example to explore the relationships.
      </p>
    </header>

    <!-- Example Tabs -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Select an example">
        {examples.map((example, idx) => (
          <button
            role="tab"
            id={`tab-${example.id}`}
            aria-selected={idx === 0 ? 'true' : 'false'}
            aria-controls={`panel-${example.id}`}
            tabindex={idx === 0 ? 0 : -1}
            data-example={example.id}
            class:list={[
              'example-tab px-4 py-2 rounded-lg font-medium text-sm transition-all border',
              idx === 0
                ? 'bg-[var(--flutter-blue)] text-white border-[var(--flutter-blue)]'
                : 'bg-[var(--bg-secondary)] text-[var(--text-secondary)] border-[var(--border)] hover:border-[var(--flutter-blue)] hover:text-[var(--text)]'
            ]}
          >
            {example.title}
          </button>
        ))}
      </div>
    </div>

    <!-- Example Panels -->
    {examples.map((example, idx) => (
      <div
        role="tabpanel"
        id={`panel-${example.id}`}
        aria-labelledby={`tab-${example.id}`}
        data-example={example.id}
        class:list={['example-panel', idx !== 0 && 'hidden']}
      >
        <p class="mb-6 text-[var(--text-secondary)]">{example.description}</p>

        <div class="grid gap-6 lg:grid-cols-2 mb-8">
          <!-- Code Panel -->
          <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] overflow-hidden">
            <div class="px-4 py-2 border-b border-[var(--border)] bg-[var(--bg-elevated)]">
              <span class="text-sm font-medium text-[var(--text-secondary)]">Flutter Code</span>
            </div>
            <pre class="p-4 overflow-x-auto text-sm leading-relaxed"><code class="font-mono text-[var(--text)]">{example.code}</code></pre>
          </div>

          <!-- Tree Visualisation -->
          <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] overflow-hidden">
            <div class="px-4 py-2 border-b border-[var(--border)] bg-[var(--bg-elevated)]">
              <span class="text-sm font-medium text-[var(--text-secondary)]">Three Trees</span>
            </div>
            <div class="p-4">
              <svg
                viewBox="0 0 600 320"
                class="w-full h-auto"
                role="img"
                aria-label={`Tree visualisation for ${example.title}`}
              >
                <!-- Column headers -->
                <text x="100" y="24" text-anchor="middle" class="tree-header widget-color" fill="var(--widget-color)">Widget</text>
                <text x="300" y="24" text-anchor="middle" class="tree-header element-color" fill="var(--element-color)">Element</text>
                <text x="500" y="24" text-anchor="middle" class="tree-header render-color" fill="var(--render-color)">RenderObject</text>

                <!-- Divider lines -->
                <line x1="200" y1="10" x2="200" y2="310" stroke="var(--svg-border)" stroke-width="1" stroke-dasharray="4 4" />
                <line x1="400" y1="10" x2="400" y2="310" stroke="var(--svg-border)" stroke-width="1" stroke-dasharray="4 4" />

                <!-- Widget Tree -->
                <g class="widget-tree">
                  {example.widgetTree.map((node, i) => {
                    const y = 60 + i * 70;
                    const x = 100;
                    return (
                      <g>
                        {node.parent && (
                          <line
                            x1={x}
                            y1={y - 35}
                            x2={x}
                            y2={y - 15}
                            stroke="var(--widget-color)"
                            stroke-width="2"
                          />
                        )}
                        <rect
                          x={x - 70}
                          y={y - 15}
                          width="140"
                          height="30"
                          rx="6"
                          fill={node.isNew ? 'var(--widget-fill-new)' : 'var(--widget-fill)'}
                          stroke="var(--widget-color)"
                          stroke-width="2"
                          class:list={[node.isNew && 'node-new']}
                        />
                        <text
                          x={x}
                          y={y + 5}
                          text-anchor="middle"
                          class="node-label"
                          fill="var(--svg-text)"
                        >
                          {node.label}
                        </text>
                        {node.isNew && (
                          <text x={x + 80} y={y + 5} class="node-badge" fill="var(--widget-color)">NEW</text>
                        )}
                      </g>
                    );
                  })}
                </g>

                <!-- Element Tree -->
                <g class="element-tree">
                  {example.elementTree.map((node, i) => {
                    const y = 60 + i * 70;
                    const x = 300;
                    return (
                      <g>
                        {node.parent && (
                          <line
                            x1={x}
                            y1={y - 35}
                            x2={x}
                            y2={y - 15}
                            stroke="var(--element-color)"
                            stroke-width="2"
                          />
                        )}
                        <rect
                          x={x - 70}
                          y={y - 15}
                          width="140"
                          height="30"
                          rx="6"
                          fill={node.isReused ? 'var(--element-fill-reused)' : 'var(--element-fill)'}
                          stroke="var(--element-color)"
                          stroke-width="2"
                        />
                        <text
                          x={x}
                          y={y + 5}
                          text-anchor="middle"
                          class="node-label"
                          fill="var(--svg-text)"
                        >
                          {node.label.length > 18 ? node.label.slice(0, 16) + '...' : node.label}
                        </text>
                        {node.isReused && (
                          <text x={x + 80} y={y + 5} class="node-badge" fill="var(--element-color)">REUSED</text>
                        )}
                      </g>
                    );
                  })}
                </g>

                <!-- Render Tree -->
                <g class="render-tree">
                  {example.renderTree.map((node, i) => {
                    const y = 60 + i * 70;
                    const x = 500;
                    // Offset for examples where render tree has fewer nodes
                    const offset = example.id === 'stateless-widget' ? 70 : 0;
                    return (
                      <g>
                        {node.parent && (
                          <line
                            x1={x}
                            y1={y - 35 + offset}
                            x2={x}
                            y2={y - 15 + offset}
                            stroke="var(--render-color)"
                            stroke-width="2"
                          />
                        )}
                        <rect
                          x={x - 70}
                          y={y - 15 + offset}
                          width="140"
                          height="30"
                          rx="6"
                          fill={node.isUpdated ? 'var(--render-fill-updated)' : 'var(--render-fill)'}
                          stroke="var(--render-color)"
                          stroke-width="2"
                        />
                        <text
                          x={x}
                          y={y + 5 + offset}
                          text-anchor="middle"
                          class="node-label"
                          fill="var(--svg-text)"
                        >
                          {node.label}
                        </text>
                        {node.isUpdated && (
                          <text x={x + 80} y={y + 5 + offset} class="node-badge" fill="var(--render-color)">UPDATED</text>
                        )}
                      </g>
                    );
                  })}
                </g>

                <!-- Connection lines between trees (horizontal arrows) -->
                <defs>
                  <marker id="arrow-widget" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
                    <path d="M0,0 L8,4 L0,8 Z" fill="var(--svg-border-medium)" />
                  </marker>
                </defs>
                {example.widgetTree.length === 1 && example.elementTree.length === 1 && (
                  <g class="connections">
                    <line x1="170" y1="60" x2="220" y2="60" stroke="var(--svg-border-medium)" stroke-width="1.5" marker-end="url(#arrow-widget)" stroke-dasharray="4 2" />
                    <line x1="370" y1="60" x2="420" y2="60" stroke="var(--svg-border-medium)" stroke-width="1.5" marker-end="url(#arrow-widget)" stroke-dasharray="4 2" />
                  </g>
                )}
              </svg>
            </div>
          </div>
        </div>

        <!-- Notes -->
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-5">
          <h3 class="text-sm font-semibold text-[var(--text)] mb-3">Key Points</h3>
          <ul class="space-y-2">
            {example.notes.map(note => (
              <li class="flex items-start gap-3 text-sm text-[var(--text-secondary)]">
                <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-[var(--flutter-blue)] shrink-0" />
                {note}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}

    <!-- Legend -->
    <div class="mt-12 pt-8 border-t border-[var(--border)]">
      <h2 class="text-lg font-semibold mb-4">Understanding the Three Trees</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 rounded-sm" style="background-color: var(--widget-color);" />
            <span class="font-medium">Widget Tree</span>
          </div>
          <p class="text-sm text-[var(--text-secondary)]">
            Immutable configuration. Describes what you want to render. Cheap to create.
          </p>
        </div>
        <div class="rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 rounded-sm" style="background-color: var(--element-color);" />
            <span class="font-medium">Element Tree</span>
          </div>
          <p class="text-sm text-[var(--text-secondary)]">
            Mutable instances. Manages lifecycle and holds State. Reused across rebuilds.
          </p>
        </div>
        <div class="rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 rounded-sm" style="background-color: var(--render-color);" />
            <span class="font-medium">RenderObject Tree</span>
          </div>
          <p class="text-sm text-[var(--text-secondary)]">
            Handles layout and painting. Expensive to create. Updated in-place when possible.
          </p>
        </div>
      </div>
    </div>
  </div>

  <style>
    :root {
      --flutter-blue: #02569B;
      --widget-color: #0175C2;
      --widget-fill: #dbeafe;
      --widget-fill-new: #bfdbfe;
      --element-color: #10b981;
      --element-fill: #d1fae5;
      --element-fill-reused: #a7f3d0;
      --render-color: #9333ea;
      --render-fill: #f3e8ff;
      --render-fill-updated: #e9d5ff;
    }

    .dark {
      --flutter-blue: #54c5f8;
      --widget-color: #38bdf8;
      --widget-fill: #0c4a6e;
      --widget-fill-new: #075985;
      --element-color: #34d399;
      --element-fill: #064e3b;
      --element-fill-reused: #065f46;
      --render-color: #c084fc;
      --render-fill: #3b0764;
      --render-fill-updated: #581c87;
    }

    .tree-header {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 600;
    }

    .node-label {
      font-family: var(--font-mono);
      font-size: 11px;
    }

    .node-badge {
      font-family: var(--font-mono);
      font-size: 8px;
      font-weight: 700;
    }

    .node-new {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    pre {
      margin: 0;
      background: transparent;
    }

    pre code {
      white-space: pre;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.example-tab');
      const panels = document.querySelectorAll('.example-panel');

      const activateTab = (tab: Element) => {
        const exampleId = tab.getAttribute('data-example');

        // Update tabs
        tabs.forEach(t => {
          const isActive = t.getAttribute('data-example') === exampleId;
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
          t.setAttribute('tabindex', isActive ? '0' : '-1');

          if (isActive) {
            t.classList.remove('bg-[var(--bg-secondary)]', 'text-[var(--text-secondary)]', 'border-[var(--border)]');
            t.classList.add('bg-[var(--flutter-blue)]', 'text-white', 'border-[var(--flutter-blue)]');
          } else {
            t.classList.add('bg-[var(--bg-secondary)]', 'text-[var(--text-secondary)]', 'border-[var(--border)]');
            t.classList.remove('bg-[var(--flutter-blue)]', 'text-white', 'border-[var(--flutter-blue)]');
          }
        });

        // Update panels
        panels.forEach(panel => {
          const isActive = panel.getAttribute('data-example') === exampleId;
          panel.classList.toggle('hidden', !isActive);
        });
      };

      tabs.forEach(tab => {
        tab.addEventListener('click', () => activateTab(tab));
      });

      // Keyboard navigation
      const tabList = document.querySelector('[role="tablist"]');
      tabList?.addEventListener('keydown', (e) => {
        const event = e as KeyboardEvent;
        const tabArray = Array.from(tabs);
        const current = tabArray.indexOf(document.activeElement as Element);
        if (current === -1) return;

        let next: number | null = null;
        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') next = (current + 1) % tabArray.length;
        else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') next = (current - 1 + tabArray.length) % tabArray.length;
        else if (event.key === 'Home') next = 0;
        else if (event.key === 'End') next = tabArray.length - 1;

        if (next !== null) {
          event.preventDefault();
          const target = tabArray[next] as HTMLElement;
          activateTab(target);
          target.focus();
        }
      });
    });
  </script>
</BaseLayout>
