---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import NoteCard from '@/components/NoteCard.astro';
import SiteStats from '@/components/SiteStats.astro';
import { sortByDate, filterDrafts } from '@/lib/utils';

const allPosts = await getCollection('posts');
const allNotes = await getCollection('notes');

const posts = sortByDate(filterDrafts(allPosts)).slice(0, 5);
const notes = sortByDate(allNotes).slice(0, 5);

const socialLinks = [
  { href: 'mailto:ankitranjan.dev@gmail.com', label: 'Email' },
  { href: 'https://github.com/ankitranjandev', label: 'GitHub' },
  { href: 'https://x.com/CubeRootX', label: 'X' },
  { href: 'https://www.linkedin.com/in/ankit-ranjan-a874b6101', label: 'LinkedIn' },
  { href: 'https://instagram.com/ankitranjandev', label: 'Instagram' },
  { href: 'https://substack.com/@ankitranjandev', label: 'Substack' },
];
---

<BaseLayout
  title="ankitranjan.dev"
  description="Senior Mobile Engineer with 7+ years experience in Flutter, Android, and iOS development across FinTech, InsurTech, and IoT."
>
  <!-- Organization/Person Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Ankit Ranjan",
    "url": "https://ankitranjan.dev",
    "image": "https://ankitranjan.dev/images/apple-touch-icon.png",
    "jobTitle": "Senior Mobile Engineer",
    "description": "Senior Mobile Engineer with 7+ years experience in Flutter, Android, and iOS development across FinTech, InsurTech, and IoT.",
    "sameAs": [
      "https://github.com/ankitranjandev",
      "https://x.com/CubeRootX",
      "https://www.linkedin.com/in/ankit-ranjan-a874b6101",
      "https://instagram.com/ankitranjandev",
      "https://substack.com/@ankitranjandev"
    ],
    "knowsAbout": ["Flutter", "Android", "iOS", "Dart", "Mobile Development", "FinTech", "IoT"]
  })} />
  <div class="content-grid py-12 md:py-20">
    <!-- Hero Section -->
    <section class="mb-16">
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl" style="line-height: 1.1;">
        Hi, I'm <span class="text-accent">Ankit Ranjan</span>
      </h1>
      <p class="mb-8 max-w-[60ch] text-lg text-[var(--text-secondary)]" style="line-height: 1.75;">
        Senior Mobile Engineer. 7+ years shipping apps across <strong class="text-[var(--text)] font-semibold">Android, iOS & Flutter</strong>. I build things that work at scale in FinTech, InsurTech, and IoT.
      </p>

      <div class="mb-8 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-5">
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-accent">Impact</h3>
          <p class="text-[var(--text-secondary)]" style="line-height: 1.6;">
            Cut policy activation failures from <strong class="text-[var(--text)] font-semibold">67% → 5%</strong> at PasarPolis. Built loan products with <strong class="text-[var(--text)] font-semibold">90%+ test coverage</strong> at Kuhoo.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-5">
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-accent">Speed</h3>
          <p class="text-[var(--text-secondary)]" style="line-height: 1.6;">
            PWA for <strong class="text-[var(--text)] font-semibold">50K users in 3 weeks</strong>. Employee benefits app in 6. Currently building BLE-connected IoT apps at uBreathe.
          </p>
        </div>
      </div>

      <p class="mb-8 max-w-[60ch] text-[var(--text-secondary)]" style="line-height: 1.75;">
        I own features end-to-end — architecture, design, native bridges, CI/CD, production monitoring. Looking for roles where I can tackle hard mobile problems and grow into architecture leadership.
      </p>

      <div class="flex flex-wrap gap-3">
        {socialLinks.map(({ href, label }) => (
          <a
            href={href}
            target={href.startsWith('mailto:') ? undefined : '_blank'}
            rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            class="inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] px-4 py-2.5 text-sm font-medium text-[var(--text)] no-underline transition-colors hover:border-accent hover:text-accent"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Site Stats -->
      <div class="mt-8">
        <SiteStats />
      </div>
    </section>

    <!-- Divider -->
    <div class="divider mb-16"></div>

    <!-- Latest Posts -->
    <section class="mb-16">
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h2 class="text-2xl font-semibold">Latest Posts</h2>
          <p class="mt-1 text-sm text-[var(--text-secondary)]">Thoughts on Flutter, mobile dev, and more</p>
        </div>
        <a href="/blog/" class="hidden text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent sm:inline-flex sm:items-center sm:gap-1">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      {posts.length > 0 ? (
        <div class="grid gap-4">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              href={`/blog/${post.id}/`}
              body={post.body}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-secondary)]">No posts yet.</p>
      )}
      <a href="/blog/" class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent sm:hidden">
        View all posts
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </section>

    <!-- Latest Notes -->
    <section>
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h2 class="text-2xl font-semibold">Notes</h2>
          <p class="mt-1 text-sm text-[var(--text-secondary)]">Quick thoughts and observations</p>
        </div>
        <a href="/notes/" class="hidden text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent sm:inline-flex sm:items-center sm:gap-1">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      {notes.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2">
          {notes.map((note) => (
            <NoteCard
              title={note.data.title}
              publishedAt={note.data.publishedAt}
              tags={note.data.tags}
              href={`/notes/${note.id}/`}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-secondary)]">No notes yet.</p>
      )}
      <a href="/notes/" class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent sm:hidden">
        View all notes
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </section>
  </div>
</BaseLayout>
