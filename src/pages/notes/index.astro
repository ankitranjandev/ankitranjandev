---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import NoteCard from '@/components/NoteCard.astro';
import { sortByDate } from '@/lib/utils';

const allNotes = await getCollection('notes');
const notes = sortByDate(allNotes);
---

<BaseLayout
  title="Notes"
  description="Short-form thoughts and quick observations about Flutter, mobile development, and software engineering."
>
  <div class="page-container py-12 md:py-16">
    <header class="mb-10">
      <h1 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">Notes</h1>
      <p class="text-lg text-[var(--text-secondary)]">
        Short-form thoughts and quick observations.
      </p>
    </header>

    {notes.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {notes.map((note) => (
          <NoteCard
            title={note.data.title}
            publishedAt={note.data.publishedAt}
            tags={note.data.tags}
            href={`/notes/${note.id}/`}
          />
        ))}
      </div>
    ) : (
      <p class="text-[var(--text-secondary)]">No notes yet.</p>
    )}
  </div>
</BaseLayout>
