---

---

<dialog
  id="search-dialog"
  class="m-0 h-full max-h-full w-full max-w-full bg-transparent p-0 backdrop:bg-black/50 md:mt-[10vh] md:h-auto md:max-h-[80vh] md:max-w-2xl md:rounded-lg"
>
  <div class="flex h-full flex-col bg-[var(--bg)] md:max-h-[80vh] md:rounded-lg md:border md:border-[var(--border)]">
    <header class="flex items-center justify-between border-b border-[var(--border)] px-4 py-3">
      <h2 class="text-lg font-semibold text-[var(--text)]">Search</h2>
      <button
        type="button"
        class="flex h-8 w-8 items-center justify-center rounded-md text-[var(--text-secondary)] transition-colors hover:bg-[var(--bg-secondary)] hover:text-[var(--text)]"
        aria-label="Close search"
        data-close-search
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </header>
    <div class="flex-1 overflow-y-auto p-4" id="search-container">
      <div id="pagefind-ui"></div>
      <p id="search-loading" class="text-center text-sm text-[var(--text-secondary)]">Loading search...</p>
      <p id="search-error" class="hidden text-center text-sm text-[var(--text-secondary)]">
        Search is not available. Please try again after the site is built.
      </p>
    </div>
  </div>
</dialog>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg-secondary);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui__search-input {
    font-size: 1rem !important;
    background: var(--bg) !important;
  }

  .pagefind-ui__result-link {
    color: var(--text) !important;
  }

  .pagefind-ui__result-link:hover {
    color: var(--color-accent) !important;
  }

  .pagefind-ui__result {
    padding: 1rem !important;
    border-radius: 0.5rem !important;
  }

  .pagefind-ui__result:hover {
    background: var(--bg-secondary) !important;
  }

  .pagefind-ui__result-excerpt {
    color: var(--text-secondary) !important;
  }

  .pagefind-ui__button {
    background: var(--bg-secondary) !important;
    color: var(--text) !important;
    border-color: var(--border) !important;
  }

  .pagefind-ui__button:hover {
    border-color: var(--color-accent) !important;
  }
</style>

<script is:inline>
  (function() {
    const dialog = document.getElementById('search-dialog');
    const closeBtn = document.querySelector('[data-close-search]');
    const loadingEl = document.getElementById('search-loading');
    const errorEl = document.getElementById('search-error');
    let pagefindLoaded = false;
    let pagefindFailed = false;

    function initPagefind() {
      if (pagefindLoaded || pagefindFailed) return;

      if (typeof window.PagefindUI === 'undefined') {
        // PagefindUI not loaded yet, show error
        pagefindFailed = true;
        if (loadingEl) loadingEl.style.display = 'none';
        if (errorEl) errorEl.classList.remove('hidden');
        return;
      }

      pagefindLoaded = true;
      if (loadingEl) loadingEl.style.display = 'none';

      new window.PagefindUI({
        element: '#pagefind-ui',
        showSubResults: true,
        showImages: false,
        autofocus: true,
      });
    }

    function loadPagefindScript() {
      if (document.querySelector('script[src="/pagefind/pagefind-ui.js"]')) {
        // Script already exists, try to init
        initPagefind();
        return;
      }

      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function() {
        initPagefind();
      };
      script.onerror = function() {
        pagefindFailed = true;
        if (loadingEl) loadingEl.style.display = 'none';
        if (errorEl) errorEl.classList.remove('hidden');
      };
      document.head.appendChild(script);
    }

    if (dialog) {
      dialog.addEventListener('click', function(e) {
        if (e.target === dialog) {
          dialog.close();
        }
      });

      dialog.addEventListener('close', function() {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) input.value = '';
      });

      dialog.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          dialog.close();
        }
      });

      // Load pagefind when dialog opens
      const observer = new MutationObserver(function() {
        if (dialog.open) {
          loadPagefindScript();
        }
      });
      observer.observe(dialog, { attributes: true, attributeFilter: ['open'] });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        if (dialog) dialog.close();
      });
    }
  })();
</script>
