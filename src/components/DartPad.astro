---
interface Props {
  id: string;
  mode?: 'flutter' | 'dart';
  height?: number;
}

const { id, mode = 'dart', height = 500 } = Astro.props;

const embedFile = mode === 'flutter' ? 'embed-flutter.html' : 'embed-dart.html';
const baseUrl = `https://dartpad.dev/${embedFile}`;
---

<div class="dartpad-embed not-prose my-6 overflow-hidden rounded-md border border-[var(--border)]" data-dartpad-id={id}>
  <div class="dartpad-placeholder flex items-center justify-center bg-[var(--bg-secondary)]" style={`height: ${height}px`}>
    <button
      type="button"
      class="flex items-center gap-2 rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      data-dartpad-load
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
      Load DartPad
    </button>
  </div>
  <noscript>
    <iframe
      src={`${baseUrl}?id=${id}&theme=light`}
      style={`width: 100%; height: ${height}px; border: none;`}
      title="DartPad"
    ></iframe>
  </noscript>
</div>

<script define:vars={{ id, baseUrl, height }}>
  const container = document.querySelector(`[data-dartpad-id="${id}"]`);
  if (container) {
    const button = container.querySelector('[data-dartpad-load]');
    const placeholder = container.querySelector('.dartpad-placeholder');

    button?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const theme = isDark ? 'dark' : 'light';
      const iframe = document.createElement('iframe');
      iframe.src = `${baseUrl}?id=${id}&theme=${theme}`;
      iframe.style.cssText = `width: 100%; height: ${height}px; border: none;`;
      iframe.title = 'DartPad';

      if (placeholder) {
        placeholder.replaceWith(iframe);
      }
    }, { once: true });
  }
</script>
