---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import NoteCard from '@/components/NoteCard.astro';
import SiteStats from '@/components/SiteStats.astro';
import { sortByDate, filterDrafts } from '@/lib/utils';

const allPosts = await getCollection('posts');
const allNotes = await getCollection('notes');
const allDives = await getCollection('deepDives');

const posts = sortByDate(filterDrafts(allPosts)).slice(0, 3);
const notes = sortByDate(allNotes).slice(0, 4);

const countFor = (category: string) =>
  allDives.filter((d) => (d.data.category || 'Dart') === category).length;

const deepDiveCategories = [
  {
    name: 'Dart',
    color: '#0175C2',
    featured: true,
    description:
      'The flagship series. Dart built up from first principles — booleans, integers, doubles, strings, collections, closures, isolates — all the way down to the VM that runs Flutter.',
  },
  {
    name: 'Swift',
    color: '#F05138',
    featured: false,
    description:
      'Value semantics, optionals, protocols, and modern concurrency — with the history behind every design decision.',
  },
  {
    name: 'Kotlin',
    color: '#7F52FF',
    featured: false,
    description:
      'Null safety, coroutines, and the pragmatic type system that won over Android.',
  },
  {
    name: 'Design Patterns',
    color: '#9333ea',
    featured: false,
    description:
      'Battle-tested answers to recurring design problems, written for Flutter developers.',
  },
  {
    name: 'Flutter',
    color: '#02569B',
    featured: false,
    description:
      'How Flutter actually works — from the widget tree to pixels on screen.',
  },
]
  .map((c) => ({
    ...c,
    count: countFor(c.name),
    slug: c.name.toLowerCase().replace(/\s+/g, '-'),
  }))
  .filter((c) => c.count > 0);

const stats = [
  { value: '7+', label: 'years shipping mobile apps' },
  { value: '67→5%', label: 'activation failures cut at PasarPolis' },
  { value: '50K', label: 'users on a PWA built in 3 weeks' },
  { value: '90%+', label: 'test coverage on lending products' },
];

const socialLinks = [
  {
    href: 'mailto:ankitranjan.dev@gmail.com',
    label: 'Email',
    stroke: true,
    svg: '<rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>',
  },
  {
    href: 'https://github.com/ankitranjandev',
    label: 'GitHub',
    stroke: false,
    svg: '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>',
  },
  {
    href: 'https://x.com/CubeRootX',
    label: 'X',
    stroke: false,
    svg: '<path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>',
  },
  {
    href: 'https://www.linkedin.com/in/ankit-ranjan-a874b6101',
    label: 'LinkedIn',
    stroke: false,
    svg: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>',
  },
  {
    href: 'https://instagram.com/ankitranjandev',
    label: 'Instagram',
    stroke: true,
    svg: '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>',
  },
  {
    href: 'https://substack.com/@ankitranjandev',
    label: 'Substack',
    stroke: false,
    svg: '<path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.539 24V10.812H1.46zM22.539 0H1.46v2.836h21.08V0z"></path>',
  },
];
---

<BaseLayout
  title="ankitranjan.dev"
  description="Senior Mobile Engineer with 7+ years experience in Flutter, Android, and iOS development across FinTech, InsurTech, and IoT."
>
  <!-- Organization/Person Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Ankit Ranjan",
    "url": "https://ankitranjan.dev",
    "image": "https://ankitranjan.dev/images/apple-touch-icon.png",
    "jobTitle": "Senior Mobile Engineer",
    "description": "Senior Mobile Engineer with 7+ years experience in Flutter, Android, and iOS development across FinTech, InsurTech, and IoT.",
    "sameAs": [
      "https://github.com/ankitranjandev",
      "https://x.com/CubeRootX",
      "https://www.linkedin.com/in/ankit-ranjan-a874b6101",
      "https://instagram.com/ankitranjandev",
      "https://substack.com/@ankitranjandev"
    ],
    "knowsAbout": ["Flutter", "Android", "iOS", "Dart", "Mobile Development", "FinTech", "IoT"]
  })} />
  <!-- WebSite Schema with SearchAction for sitelinks search box -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ankitranjan.dev",
    "url": "https://ankitranjan.dev",
    "description": "Technical blog and portfolio of Ankit Ranjan — Dart deep-dives, Flutter, and mobile engineering.",
    "publisher": {
      "@type": "Person",
      "name": "Ankit Ranjan",
      "url": "https://ankitranjan.dev"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://ankitranjan.dev/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <div class="page-container py-12 md:py-20">
    <!-- Hero -->
    <section class="relative mb-20">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-32 left-1/2 h-[420px] w-[680px] max-w-full -translate-x-1/2 rounded-full opacity-[0.08] blur-3xl"
        style="background: radial-gradient(closest-side, #2563eb, transparent);"
      >
      </div>

      <p class="anim anim-1 mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--bg-secondary)] px-3.5 py-1.5 text-sm font-medium text-[var(--text-secondary)]">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75 motion-reduce:hidden"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        Open to senior mobile roles
      </p>

      <h1 class="anim anim-2 mb-6 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl" style="line-height: 1.08;">
        Hi, I'm <span class="text-accent">Ankit Ranjan</span>.
      </h1>

      <p class="anim anim-3 mb-8 max-w-[58ch] text-lg text-[var(--text-secondary)] md:text-xl" style="line-height: 1.7;">
        Senior mobile engineer — 7+ years shipping
        <strong class="font-semibold text-[var(--text)]">Android, iOS &amp; Flutter</strong>
        apps in FinTech, InsurTech, and IoT. I own features end-to-end: architecture, native bridges, CI/CD, and what happens after release.
      </p>

      <div class="anim anim-4 mb-8 flex flex-wrap items-center gap-3">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 font-medium text-white no-underline shadow-sm transition-all hover:bg-accent-hover hover:shadow-md"
        >
          Get in touch
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/work/"
          class="inline-flex items-center rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] px-5 py-2.5 font-medium text-[var(--text)] no-underline transition-colors hover:border-accent hover:text-accent"
        >
          See my work
        </a>

        <span aria-hidden="true" class="mx-1 hidden h-6 w-px bg-[var(--border)] sm:block"></span>

        <ul class="flex items-center gap-1.5" aria-label="Social links">
          {socialLinks.map(({ href, label, svg, stroke }) => (
            <li>
              <a
                href={href}
                target={href.startsWith('mailto:') ? undefined : '_blank'}
                rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
                aria-label={label}
                title={label}
                class="flex h-10 w-10 items-center justify-center rounded-full border border-transparent text-[var(--text-secondary)] transition-all hover:border-[var(--border)] hover:bg-[var(--bg-secondary)] hover:text-accent"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill={stroke ? 'none' : 'currentColor'}
                  stroke={stroke ? 'currentColor' : 'none'}
                  stroke-width={stroke ? '2' : undefined}
                  stroke-linecap={stroke ? 'round' : undefined}
                  stroke-linejoin={stroke ? 'round' : undefined}
                  aria-hidden="true"
                  set:html={svg}
                />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Proof, not prose: the numbers behind the pitch -->
      <dl class="anim anim-5 grid grid-cols-2 gap-x-6 gap-y-8 border-y border-[var(--border)] py-8 sm:grid-cols-4">
        {stats.map(({ value, label }) => (
          <div class="flex flex-col gap-1">
            <dd class="order-1 whitespace-nowrap text-2xl font-bold tracking-tight text-[var(--text)] md:text-3xl">
              {value}
            </dd>
            <dt class="order-2 text-sm text-[var(--text-secondary)]" style="line-height: 1.45;">
              {label}
            </dt>
          </div>
        ))}
      </dl>
    </section>

    <!-- Deep Dives -->
    <section class="mb-0">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold md:text-3xl">Deep Dives</h2>
          <p class="mt-1.5 max-w-[55ch] text-[var(--text-secondary)]">
            Long-form series that build languages up from first principles — and the patterns to use them well.
          </p>
        </div>
        <a href="/deep-dives/" class="shrink-0 whitespace-nowrap text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </section>

    <div class="mb-20">
      <div class="grid gap-4 sm:grid-cols-2">
        {deepDiveCategories.map(({ name, color, count, slug, description, featured }) => (
          <a
            href={`/deep-dives/#${slug}`}
            class:list={[
              'group relative block overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-secondary)] p-6 no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--cat)] hover:shadow-lg motion-reduce:transition-none motion-reduce:hover:translate-y-0',
              featured && 'sm:col-span-2',
            ]}
            style={`--cat: ${color}`}
          >
            <span
              aria-hidden="true"
              class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100 motion-reduce:transition-none"
              style={`background-color: ${color}`}
            ></span>
            <div class="mb-3 flex items-center justify-between gap-3">
              <span class="flex items-center gap-2.5">
                <span class="h-3 w-3 rounded-full" style={`background-color: ${color}`} aria-hidden="true"></span>
                <span class="text-lg font-semibold text-[var(--text)] transition-colors group-hover:text-[var(--cat)]">{name}</span>
              </span>
              <span class="rounded-full border border-[var(--border)] bg-[var(--bg)] px-2.5 py-0.5 text-xs font-medium tabular-nums text-[var(--text-secondary)]">
                {count} {count === 1 ? 'episode' : 'episodes'}
              </span>
            </div>
            <p class:list={['text-[var(--text-secondary)]', featured ? 'max-w-[65ch]' : 'text-sm']} style="line-height: 1.6;">
              {description}
            </p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--text-tertiary)] transition-colors group-hover:text-[var(--cat)]">
              Start learning
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5 motion-reduce:transition-none" aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Latest Posts -->
    <section class="mb-20">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold md:text-3xl">Latest Posts</h2>
          <p class="mt-1.5 text-[var(--text-secondary)]">Thoughts on Flutter, mobile dev, and more.</p>
        </div>
        <a href="/blog/" class="shrink-0 whitespace-nowrap text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      {posts.length > 0 ? (
        <div class="grid gap-4 lg:grid-cols-3">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              href={`/blog/${post.id}/`}
              body={post.body}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-secondary)]">No posts yet.</p>
      )}
    </section>

    <!-- Latest Notes -->
    <section class="mb-16">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold md:text-3xl">Notes</h2>
          <p class="mt-1.5 text-[var(--text-secondary)]">Quick thoughts and observations.</p>
        </div>
        <a href="/notes/" class="shrink-0 whitespace-nowrap text-sm font-medium text-[var(--text-secondary)] no-underline transition-colors hover:text-accent">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      {notes.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2">
          {notes.map((note) => (
            <NoteCard
              title={note.data.title}
              publishedAt={note.data.publishedAt}
              tags={note.data.tags}
              href={`/notes/${note.id}/`}
            />
          ))}
        </div>
      ) : (
        <p class="text-[var(--text-secondary)]">No notes yet.</p>
      )}
    </section>

    <!-- Site meta -->
    <div class="flex justify-center border-t border-[var(--border-subtle)] pt-8">
      <SiteStats />
    </div>
  </div>
</BaseLayout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .anim {
      opacity: 0;
      animation: rise 0.55s cubic-bezier(0.21, 0.47, 0.32, 0.98) forwards;
    }
    .anim-1 { animation-delay: 0.03s; }
    .anim-2 { animation-delay: 0.09s; }
    .anim-3 { animation-delay: 0.16s; }
    .anim-4 { animation-delay: 0.24s; }
    .anim-5 { animation-delay: 0.33s; }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
