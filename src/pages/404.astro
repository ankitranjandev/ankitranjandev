---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist."
  noIndex
>
  <div class="page-container flex min-h-[60vh] flex-col items-center justify-center py-12 text-center md:py-16">
    <h1 class="mb-4 text-6xl font-bold text-[var(--text-secondary)]">404</h1>
    <p class="mb-8 text-xl text-[var(--text-secondary)]">
      This page doesn't exist.
    </p>
    <a
      href="/"
      class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-accent-fg no-underline transition-colors hover:bg-accent-hover"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
