---
// Site Statistics Component
// Fetches visitor stats from Cloudflare Analytics Worker
---

<div id="site-stats" class="inline-flex items-center gap-2 text-sm text-[var(--text-secondary)]">
  <span class="flex items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
      <circle cx="9" cy="7" r="4"></circle>
      <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
    </svg>
    <span id="visitor-count" class="tabular-nums">—</span>
    <span>visitors</span>
  </span>
  <span class="text-[var(--border)]">·</span>
  <span class="flex items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>
    <span id="pageview-count" class="tabular-nums">—</span>
    <span>views</span>
  </span>
  <span class="text-xs text-[var(--text-tertiary)]">(30d)</span>
</div>

<script>
  const ANALYTICS_API = 'https://analytics-api.ankitranjandev.workers.dev';

  async function fetchStats() {
    try {
      const response = await fetch(ANALYTICS_API);
      if (!response.ok) throw new Error('Failed to fetch');

      const data = await response.json();

      const visitorEl = document.getElementById('visitor-count');
      const pageviewEl = document.getElementById('pageview-count');

      if (visitorEl && data.visitors) {
        visitorEl.textContent = formatNumber(data.visitors);
      }
      if (pageviewEl && data.pageViews) {
        pageviewEl.textContent = formatNumber(data.pageViews);
      }
    } catch (error) {
      console.log('Stats unavailable');
    }
  }

  function formatNumber(num: number): string {
    if (num >= 1000000) {
      return (num / 1000000).toFixed(1) + 'M';
    }
    if (num >= 1000) {
      return (num / 1000).toFixed(1) + 'K';
    }
    return num.toLocaleString();
  }

  // Fetch on load
  fetchStats();
</script>
