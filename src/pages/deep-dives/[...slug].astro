---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Prose from '@/components/Prose.astro';
import DeepDiveTOC from '@/components/DeepDiveTOC.astro';
import Quiz from '@/components/Quiz.astro';
import ShareLinks from '@/components/ShareLinks.astro';
import { formatDate } from '@/lib/utils';

export async function getStaticPaths() {
  const deepDives = await getCollection('deepDives');
  return deepDives.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogType="article"
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
>
  <!-- Article Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": entry.data.title,
    "description": entry.data.description,
    "url": canonicalURL,
    "datePublished": entry.data.publishedAt.toISOString(),
    "dateModified": (entry.data.updatedAt || entry.data.publishedAt).toISOString(),
    "author": {
      "@type": "Person",
      "name": "Ankit Ranjan",
      "url": "https://ankitranjan.dev"
    },
    "publisher": {
      "@type": "Person",
      "name": "Ankit Ranjan",
      "url": "https://ankitranjan.dev"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalURL
    },
    "articleSection": "Deep Dives",
    "keywords": [entry.data.category, entry.data.subject, entry.data.title]
  })} />

  <!-- Breadcrumb Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://ankitranjan.dev"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Deep Dives",
        "item": "https://ankitranjan.dev/deep-dives/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": entry.data.title,
        "item": canonicalURL
      }
    ]
  })} />
  <div class="content-grid py-12 md:py-16">
    <header class="mb-8">
      <a
        href="/deep-dives/"
        class="mb-4 inline-flex items-center gap-2 text-sm text-[var(--text-secondary)] no-underline transition-colors hover:text-[var(--text)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Back to Deep Dives
      </a>
      <h1 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">{entry.data.title}</h1>
      <p class="mb-4 text-lg text-[var(--text-secondary)]">
        {entry.data.description}
      </p>
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-tertiary)]">
          <span>{formatDate(entry.data.publishedAt)}</span>
          <span class="hidden sm:inline">·</span>
          <span>{entry.data.topics.length} topics</span>
          <span class="hidden sm:inline">·</span>
          <span>{entry.data.quiz.questions.length} quiz questions</span>
        </div>
        <ShareLinks title={entry.data.title} url={canonicalURL} />
      </div>
    </header>

    <div class="deep-dive-layout breakout">
      <!-- Sidebar TOC -->
      <DeepDiveTOC topics={entry.data.topics} />

      <!-- Main content -->
      <div class="deep-dive-content">
        <!-- Topics -->
        <div class="space-y-8 md:space-y-12" id="topics-container">
          {entry.data.topics.map((topic, index) => (
            <section
              id={topic.id}
              class="topic-section scroll-mt-24 rounded-xl border border-[var(--border)] bg-[var(--bg-secondary)] p-5 md:p-8"
            >
              <div class="mb-4 flex items-center gap-3">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-sm font-bold text-accent">
                  {index + 1}
                </span>
                <h2 class="text-lg font-semibold text-[var(--text)] md:text-2xl">{topic.title}</h2>
              </div>
              <div class="prose-custom topic-summary text-[var(--text-secondary)]">
                <p set:html={topic.summary} />
              </div>
            </section>
          ))}
        </div>

        <!-- MDX Content (additional content if any) -->
        {entry.body && entry.body.trim() && (
          <div class="mt-12">
            <Prose>
              <Content />
            </Prose>
          </div>
        )}

        <!-- Quiz Section -->
        <div class="divider my-12"></div>
        <Quiz
          title={entry.data.quiz.title}
          description={entry.data.quiz.description}
          questions={entry.data.quiz.questions}
          subjectTitle={entry.data.title}
        />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .deep-dive-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .deep-dive-content {
    min-width: 0;
    flex: 1;
  }

  @media (min-width: 1024px) {
    .deep-dive-layout {
      flex-direction: row;
      gap: 3rem;
    }
  }
</style>

<script>
  // Add copy buttons to all pre elements in topic summaries
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('.topic-summary pre');

    codeBlocks.forEach(pre => {
      // Create copy button
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
      `;

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (code) {
          await navigator.clipboard.writeText(code.textContent || '');
          btn.classList.add('copied');
          btn.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          `;
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
            `;
          }, 2000);
        }
      });

      pre.appendChild(btn);
    });
  });
</script>
